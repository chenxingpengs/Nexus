<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:model="clr-namespace:Nexus.Models.Widget"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="Nexus.Views.Widget.Cards.WeatherCardView"
             x:DataType="model:WeatherCardModel">

    <Border Background="#F5F5F5"
            CornerRadius="10"
            Padding="14"
            BorderBrush="#1A000000"
            BorderThickness="1">
        
        <Grid>
            <Grid RowDefinitions="Auto,Auto" IsVisible="{Binding !IsNotConfigured}">
                
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="{Binding Temperature, StringFormat={}{0:F0}}"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   Foreground="#1976D2"/>
                        <TextBlock Text="°C"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1976D2"
                                   VerticalAlignment="Top"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="{Binding Weather}" 
                                   FontSize="18" 
                                   FontWeight="Medium"
                                   Foreground="#424242"/>
                        <TextBlock FontSize="14" Foreground="#757575" Margin="0,2,0,0">
                            <Run Text="{Binding TempMin}"/>
                            <Run Text="° / "/>
                            <Run Text="{Binding TempMax}"/>
                            <Run Text="°"/>
                        </TextBlock>
                    </StackPanel>
                    
                    <TextBlock Grid.Column="2" 
                               Text="{Binding City}" 
                               FontSize="14"
                               Foreground="#757575"
                               VerticalAlignment="Center"/>
                </Grid>
                
                <Grid Grid.Row="1" ColumnDefinitions="*,*,*" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <ui:SymbolIcon Symbol="{x:Static ui:Symbol.Clear}" FontSize="16" Foreground="#1976D2"/>
                        <TextBlock FontSize="14" Foreground="#616161" VerticalAlignment="Center">
                            <Run Text="湿度 "/>
                            <Run Text="{Binding Humidity}"/>
                            <Run Text="%"/>
                        </TextBlock>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                        <ui:SymbolIcon Symbol="{x:Static ui:Symbol.AllApps}" FontSize="16" Foreground="#1976D2"/>
                        <TextBlock FontSize="14" Foreground="#616161" VerticalAlignment="Center">
                            <Run Text="空气 "/>
                            <Run Text="{Binding AirQuality}"/>
                        </TextBlock>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6"
                               IsVisible="{Binding FeelsLike, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <ui:SymbolIcon Symbol="{x:Static ui:Symbol.Setting}" FontSize="16" Foreground="#1976D2"/>
                        <TextBlock FontSize="14" Foreground="#616161" VerticalAlignment="Center">
                            <Run Text="体感 "/>
                            <Run Text="{Binding FeelsLike}"/>
                            <Run Text="°"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
                
            </Grid>
            
            <StackPanel HorizontalAlignment="Center" 
                        VerticalAlignment="Center"
                        Spacing="8"
                        IsVisible="{Binding IsNotConfigured}">
                <ui:SymbolIcon Symbol="{x:Static ui:Symbol.Important}" FontSize="28" Foreground="#FF9800"/>
                <TextBlock Text="{Binding Message}" 
                           FontSize="14" 
                           Foreground="#757575"
                           TextAlignment="Center"/>
            </StackPanel>
        </Grid>
        
    </Border>
    
</UserControl>
