<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:model="clr-namespace:Nexus.Models.Widget"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="Nexus.Views.Widget.Cards.AnnouncementCardView"
             x:DataType="model:AnnouncementCardModel">

    <Border Background="#F5F5F5"
            CornerRadius="12"
            Padding="16"
            BorderBrush="#1A000000"
            BorderThickness="1">
        
        <Grid RowDefinitions="Auto,*">
            
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                <ui:SymbolIcon Symbol="Alert" FontSize="20" Foreground="#1976D2"/>
                <TextBlock Text="公告" 
                           FontSize="16" 
                           FontWeight="Medium"
                           Foreground="#424242"
                           VerticalAlignment="Center"/>
            </StackPanel>
            
            <ItemsControl Grid.Row="1" ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FFFFFF" 
                                CornerRadius="8" 
                                Padding="12,8" 
                                Margin="0,0,0,8">
                            <Grid ColumnDefinitions="Auto,*">
                                <Border Background="#FFEBEE"
                                        CornerRadius="4"
                                        Padding="6,2"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="公告"
                                               FontSize="11"
                                               Foreground="#E81123"
                                               FontWeight="Medium"/>
                                </Border>
                                
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="13"
                                               FontWeight="Medium"
                                               Foreground="#424242"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Content}"
                                               FontSize="12"
                                               Foreground="#757575"
                                               MaxLines="2"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding TimeAgo}"
                                               FontSize="11"
                                               Foreground="#9E9E9E"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            
            <StackPanel Grid.Row="1" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsEmpty}">
                <ui:SymbolIcon Symbol="Help" FontSize="24" Foreground="#BDBDBD"/>
                <TextBlock Text="暂无公告" 
                           FontSize="13" 
                           Foreground="#9E9E9E"
                           Margin="0,8,0,0"/>
            </StackPanel>
            
        </Grid>
    </Border>
    
</UserControl>
