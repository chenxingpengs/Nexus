<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:model="clr-namespace:Nexus.Models.Widget"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="Nexus.Views.Widget.Cards.ShortcutCardView"
             x:DataType="model:ShortcutCardModel">

    <Border Background="#F5F5F5"
            CornerRadius="12"
            Padding="12"
            BorderBrush="#1A000000"
            BorderThickness="1">
        
        <StackPanel>
            
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ui:SymbolIcon Symbol="{x:Static ui:Symbol.More}" 
                                   FontSize="18" 
                                   Foreground="#1976D2"/>
                    <TextBlock Text="快捷栏" 
                               FontSize="14" 
                               FontWeight="Medium"
                               Foreground="#424242"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
            
            <StackPanel Orientation="Horizontal" Spacing="8">
                
                <Button x:Name="UsbButton"
                        Width="60"
                        Height="60"
                        Padding="0"
                        CornerRadius="12"
                        Background="#E3F2FD"
                        BorderThickness="0"
                        IsVisible="{Binding HasUsbDrives}">
                    <StackPanel Spacing="4">
                        <ui:SymbolIcon Symbol="{x:Static ui:Symbol.Save}" 
                                       FontSize="24" 
                                       Foreground="#1976D2"/>
                        <TextBlock Text="U盘" 
                                   FontSize="11" 
                                   Foreground="#424242"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button x:Name="DocumentCameraButton"
                        Width="60"
                        Height="60"
                        Padding="0"
                        CornerRadius="12"
                        Background="#E8F5E9"
                        BorderThickness="0"
                        IsVisible="{Binding HasDocumentCamera}">
                    <StackPanel Spacing="4">
                        <ui:SymbolIcon Symbol="{x:Static ui:Symbol.Video}" 
                                       FontSize="24" 
                                       Foreground="#4CAF50"/>
                        <TextBlock Text="{Binding DocumentCameraName}" 
                                   FontSize="10" 
                                   Foreground="#424242"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="54"/>
                    </StackPanel>
                </Button>
                
                <Border Width="60"
                        Height="60"
                        CornerRadius="12"
                        Background="#FAFAFA"
                        IsVisible="{Binding !HasUsbDrives}">
                    <StackPanel Spacing="4" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="{x:Static ui:Symbol.Save}" 
                                       FontSize="24" 
                                       Foreground="#BDBDBD"/>
                        <TextBlock Text="无U盘" 
                                   FontSize="11" 
                                   Foreground="#9E9E9E"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
            </StackPanel>
            
        </StackPanel>
        
    </Border>
    
</UserControl>
