<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:vm="clr-namespace:Nexus.ViewModels.Pages"
             x:Class="Nexus.Views.Pages.SettingsPage"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer>
        <StackPanel Spacing="20" Margin="0,0,0,32">
            
            <StackPanel Spacing="8" Margin="0,0,0,8">
                <TextBlock Text="设置"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#1976D2"/>
                <TextBlock Text="管理设备和应用程序设置"
                           FontSize="14"
                           Foreground="#757575"/>
            </StackPanel>

            <Border Background="#FFFFFF" CornerRadius="12" Padding="24"
                    BoxShadow="0 2 8 0 #1A000000">
                <StackPanel Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Background="#E3F2FD" CornerRadius="8" Padding="10">
                            <ui:SymbolIcon Symbol="{x:Static ui:Symbol.Video}" FontSize="20" Foreground="#1976D2"/>
                        </Border>
                        <TextBlock Text="设备信息" FontSize="18" FontWeight="SemiBold" Foreground="#424242" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <Border Background="#F5F5F5" CornerRadius="8" Padding="16">
                        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="设备ID" 
                                       FontSize="13" Foreground="#757575" VerticalAlignment="Center"/>
                            <Border Grid.Row="0" Grid.Column="1" Background="#FFFFFF" CornerRadius="4" Padding="8,4">
                                <TextBlock Text="{Binding DeviceId}" 
                                           FontFamily="Consolas" FontSize="13"
                                           Foreground="#424242"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="设备名称" 
                                       FontSize="13" Foreground="#757575" VerticalAlignment="Center" Margin="0,12,0,0"/>
                            <Border Grid.Row="1" Grid.Column="1" Background="#FFFFFF" CornerRadius="4" Padding="8,4" Margin="0,12,0,0">
                                <TextBlock Text="{Binding DeviceName}" 
                                           FontSize="13"
                                           Foreground="#424242"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="绑定班级" 
                                       FontSize="13" Foreground="#757575" VerticalAlignment="Center" Margin="0,12,0,0"/>
                            <Border Grid.Row="2" Grid.Column="1" Background="#FFFFFF" CornerRadius="4" Padding="8,4" Margin="0,12,0,0">
                                <TextBlock Text="{Binding ClassName}" 
                                           FontSize="13"
                                           Foreground="#424242"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Background="#FFFFFF" CornerRadius="12" Padding="24"
                    BoxShadow="0 2 8 0 #1A000000">
                <StackPanel Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Background="#E8F5E9" CornerRadius="8" Padding="10">
                            <ui:SymbolIcon Symbol="{x:Static ui:Symbol.Globe}" FontSize="20" Foreground="#4CAF50"/>
                        </Border>
                        <TextBlock Text="服务器设置" FontSize="18" FontWeight="SemiBold" Foreground="#424242" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <Border Background="#F5F5F5" CornerRadius="8" Padding="16">
                        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="服务器地址" 
                                       FontSize="13" Foreground="#757575" VerticalAlignment="Center"/>
                            <Border Grid.Row="0" Grid.Column="1" Background="#FFFFFF" CornerRadius="4" Padding="8,4">
                                <TextBlock Text="{Binding ServerUrl}" 
                                           FontSize="13"
                                           Foreground="#424242"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Background="#FFFFFF" CornerRadius="12" Padding="24"
                    BoxShadow="0 2 8 0 #1A000000">
                <StackPanel Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Background="#FFF3E0" CornerRadius="8" Padding="10">
                            <ui:SymbolIcon Symbol="{x:Static ui:Symbol.Setting}" FontSize="20" Foreground="#FF9800"/>
                        </Border>
                        <TextBlock Text="应用设置" FontSize="18" FontWeight="SemiBold" Foreground="#424242" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <Border Background="#F5F5F5" CornerRadius="8" Padding="16">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="开机自启动" FontSize="14" Foreground="#424242" FontWeight="Medium"/>
                                <TextBlock Text="系统启动时自动运行程序" FontSize="12" Foreground="#9E9E9E"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Row="0" Grid.Column="1" 
                                          IsChecked="{Binding AutoStart}"
                                          VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
