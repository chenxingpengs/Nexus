<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="Nexus.Views.Pages.DashboardPage">

    <ScrollViewer>
        <StackPanel Spacing="20" Margin="0,0,0,32">
            
            <StackPanel Spacing="8" Margin="0,0,0,8">
                <TextBlock Text="设备概览"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#1976D2"/>
                <TextBlock Text="查看设备运行状态和基本信息"
                           FontSize="14"
                           Foreground="#757575"/>
            </StackPanel>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">
                
                <Border Grid.Column="0" Background="#FFFFFF" CornerRadius="12" Padding="20"
                        BoxShadow="0 2 8 0 #1A000000">
                    <StackPanel Spacing="12">
                        <Border Background="#E3F2FD" CornerRadius="10" Width="48" Height="48" Padding="12">
                            <ui:SymbolIcon Symbol="{x:Static ui:Symbol.Video}" FontSize="24" Foreground="#1976D2"/>
                        </Border>
                        <TextBlock Text="设备状态" FontSize="13" Foreground="#757575" FontWeight="Medium"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="10" Height="10" Fill="#4CAF50"/>
                            <TextBlock Text="在线运行中" FontSize="20" FontWeight="SemiBold" Foreground="#4CAF50"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#FFFFFF" CornerRadius="12" Padding="20"
                        BoxShadow="0 2 8 0 #1A000000">
                    <StackPanel Spacing="12">
                        <Border Background="#E8F5E9" CornerRadius="10" Width="48" Height="48" Padding="12">
                            <ui:SymbolIcon Symbol="{x:Static ui:Symbol.People}" FontSize="24" Foreground="#4CAF50"/>
                        </Border>
                        <TextBlock Text="今日考勤" FontSize="13" Foreground="#757575" FontWeight="Medium"/>
                        <TextBlock Text="--" FontSize="20" FontWeight="SemiBold" Foreground="#424242"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#FFFFFF" CornerRadius="12" Padding="20"
                        BoxShadow="0 2 8 0 #1A000000">
                    <StackPanel Spacing="12">
                        <Border Background="#FFF3E0" CornerRadius="10" Width="48" Height="48" Padding="12">
                            <ui:SymbolIcon Symbol="{x:Static ui:Symbol.Clock}" FontSize="24" Foreground="#FF9800"/>
                        </Border>
                        <TextBlock Text="运行时间" FontSize="13" Foreground="#757575" FontWeight="Medium"/>
                        <TextBlock Text="--" FontSize="20" FontWeight="SemiBold" Foreground="#424242"/>
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Spacing="12" Margin="0,8,0,0">
                <TextBlock Text="快捷操作"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#424242"/>
                <TextBlock Text="常用功能快速访问"
                           FontSize="13"
                           Foreground="#9E9E9E"/>
            </StackPanel>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <Border Background="#FFFFFF" CornerRadius="12" Padding="20" Cursor="Hand"
                        BoxShadow="0 2 8 0 #1A000000">
                    <Border.Styles>
                        <Style Selector="Border">
                            <Setter Property="Transitions">
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                                </Transitions>
                            </Setter>
                        </Style>
                        <Style Selector="Border:pointerover">
                            <Setter Property="Opacity" Value="0.9"/>
                        </Style>
                    </Border.Styles>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <Border Background="#E3F2FD" CornerRadius="10" Width="44" Height="44" Padding="10">
                            <ui:SymbolIcon Symbol="{x:Static ui:Symbol.Refresh}" FontSize="22" Foreground="#1976D2"/>
                        </Border>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="刷新状态" FontSize="16" FontWeight="SemiBold" Foreground="#424242"/>
                            <TextBlock Text="重新获取设备信息" FontSize="12" Foreground="#9E9E9E"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#FFFFFF" CornerRadius="12" Padding="20" Cursor="Hand"
                        BoxShadow="0 2 8 0 #1A000000">
                    <Border.Styles>
                        <Style Selector="Border">
                            <Setter Property="Transitions">
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                                </Transitions>
                            </Setter>
                        </Style>
                        <Style Selector="Border:pointerover">
                            <Setter Property="Opacity" Value="0.9"/>
                        </Style>
                    </Border.Styles>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <Border Background="#F3E5F5" CornerRadius="10" Width="44" Height="44" Padding="10">
                            <ui:SymbolIcon Symbol="{x:Static ui:Symbol.Document}" FontSize="22" Foreground="#9C27B0"/>
                        </Border>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="查看日志" FontSize="16" FontWeight="SemiBold" Foreground="#424242"/>
                            <TextBlock Text="查看设备运行日志" FontSize="12" Foreground="#9E9E9E"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Spacing="12" Margin="0,8,0,0">
                <TextBlock Text="系统公告"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#424242"/>
                <TextBlock Text="最新通知和更新信息"
                           FontSize="13"
                           Foreground="#9E9E9E"/>
            </StackPanel>

            <Border Background="#FFFFFF" CornerRadius="12" Padding="24"
                    BoxShadow="0 2 8 0 #1A000000">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Background="#FFF8E1" CornerRadius="8" Padding="8">
                            <ui:SymbolIcon Symbol="{x:Static ui:Symbol.Alert}" FontSize="18" Foreground="#FFA000"/>
                        </Border>
                        <TextBlock Text="暂无公告" 
                                   FontSize="15" 
                                   Foreground="#9E9E9E"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
